# Postgres
DATABASE_URL=postgres://chiirl:chiirl@localhost:5432/chiirl

# Resend (email)
RESEND_API_KEY=
RESEND_FROM_EMAIL=events@yourdomain.com

# Web Push (VAPID keys - generate with: bunx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com

# Admin (comma-separated list of admin emails)
ADMIN_EMAILS=admin@example.com

# App
FRONTEND_URL=http://localhost:5173
PORT=3000

# Frontend (SvelteKit adapter-node)
ORIGIN=http://localhost:5173
